# Frontend (Vite) environment — copy to frontend/.env

VITE_API_URL=/api/v1
VITE_APP_NAME=SmartSched

# Real authentication via Clerk. Set this to your Clerk publishable key to turn
# on real sign-in/up; leave it unset to use the local mock auth store (dev).
# Get it from dashboard.clerk.com → API Keys.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
