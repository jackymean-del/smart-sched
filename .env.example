# SmartSched v3 Environment Variables
# Copy to .env and fill in

# Server
PORT=8080
SKIP_AUTH=false
ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.com
JWT_SECRET=change-me-to-a-secure-random-string-in-production

# Database — PostgreSQL 17 (Supabase / Neon / local)
DATABASE_URL=postgresql://user:password@host:5432/smartsched?sslmode=require

# Auth — Better Auth or Clerk
BETTER_AUTH_SECRET=change-me
BETTER_AUTH_URL=http://localhost:8080
# OR use Clerk:
# CLERK_SECRET_KEY=sk_live_xxxxx
# CLERK_PUBLISHABLE_KEY=pk_live_xxxxx

# Frontend (Vite)
VITE_API_URL=/api/v1
VITE_APP_NAME=SmartSched
