# SmartSched v3 Environment Variables
# Copy to .env and fill in

# Server
PORT=8080
SKIP_AUTH=false
ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.com
JWT_SECRET=change-me-to-a-secure-random-string-in-production

# Database — PostgreSQL 17 (Supabase / Neon / local)
DATABASE_URL=postgresql://user:password@host:5432/smartsched?sslmode=require

# Auth — Clerk (real authentication). Get keys from dashboard.clerk.com.
# Backend verifies Clerk session JWTs when CLERK_SECRET_KEY is set; otherwise it
# falls back to JWT_SECRET, or dev mode (SKIP_AUTH / any token).
CLERK_SECRET_KEY=sk_test_xxxxx

# Email (SMTP) — used to send one-time codes for email-restricted timetable
# shares. If SMTP_HOST is unset, codes are logged to the API console instead
# (fine for local dev). Works with any SMTP provider (Resend, Postmark, SES…).
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=your-smtp-password
# SMTP_FROM=no-reply@schedu.bhusku.com

# Frontend (Vite) — put these in frontend/.env (or root .env)
VITE_API_URL=/api/v1
VITE_APP_NAME=SmartSched
# REQUIRED to enable real auth in the SPA. Without it the app uses the local
# mock auth store (dev). Must match the CLERK_SECRET_KEY's Clerk instance.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
